    {
      "parameters": {
        "fromEmail": "ai-os-orchestrator@yourdomain.com",
        "toEmail": "developer@yourdomain.com",
        "subject": "=✅ PR Review Completed for #{{ $json.pr_number }}",
        "html": "={{ $json.comment_body }}",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
      "id": "send-review-email",
