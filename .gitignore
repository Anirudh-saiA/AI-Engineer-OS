# ==============================================================================
# AI-Engineer-OS Monorepo GitIgnore
# ==============================================================================

# OS / System
.DS_Store
Thumbs.db
desktop.ini
*.tmp
*.bak

# IDEs and Editors
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==============================================================================
# Frontend (Next.js & Node.js)
# ==============================================================================
node_modules/
/frontend/node_modules/
/frontend/.next/
/frontend/out/
/frontend/build/
/frontend/dist/
/frontend/.docusaurus/
/frontend/yarn-error.log

# Frontend local env files
/frontend/.env.local
/frontend/.env.development.local
/frontend/.env.test.local
/frontend/.env.production.local

# Vercel deployment
.vercel

# ==============================================================================
# Backend (FastAPI & Python)
# ==============================================================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Jupyter Notebooks
.ipynb_checkpoints

# Environments
.env
.venv
venv/
ENV/
env/
pythonenv/
active_env/
conda-env/

# Backend local env files
/backend/.env
/backend/.venv/
/backend/venv/

# ==============================================================================
# AI Engine & RAG System
# ==============================================================================
/rag-system/storage/
/rag-system/index_cache/
/ai-engine/models/
/ai-engine/cache/
*.db
*.sqlite

# ==============================================================================
# Databases & Local Storage
# ==============================================================================
postgres-data/
qdrant-data/
redis-data/
data/
*.rdb

# ==============================================================================
# Deployment
# ==============================================================================
/deployment/.env
/deployment/secrets/
